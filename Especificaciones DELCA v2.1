7.3 Sistema de respaldo automático
La BD principal (delca.db) NUNCA se borra ni se modifica por el proceso de backup. Los backups son COPIAS adicionales independientes.
# config.py
BACKUP_DIAS_RETENER = 30   # Ajustable según necesidad

# database/backup.py
def backup_diario():
    """Se ejecuta al iniciar la app, una vez por día."""
    origen  = DB_PATH                     # data/delca.db — INTACTO
    fecha   = datetime.now().strftime('%Y%m%d')
    destino = os.path.join(BACKUP_DIR, f'delca_{fecha}.db')

    if not os.path.exists(destino):       # Solo una copia por día
        shutil.copy2(origen, destino)
        logger.info(f'Backup creado: {destino}')

    # Limpiar copias más antiguas que BACKUP_DIAS_RETENER
    # (solo borra las COPIAS, nunca delca.db)
    archivos = sorted(glob.glob(os.path.join(BACKUP_DIR, 'delca_*.db')))
    while len(archivos) > BACKUP_DIAS_RETENER:
        os.remove(archivos.pop(0))
        logger.info(f'Backup antiguo eliminado: {archivos[0]}')
