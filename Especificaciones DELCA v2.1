Implementación en código — decorador de permiso para cada función restringida:
# config.py
PERMISOS = {
    'ADMIN': ['ver_kpi','editar_kpi','editar_metas','ver_financiero',
              'agregar_abono','editar_abono','editar_precio_cliente',
              'editar_precio_servicio','eliminar_tiquete','editar_tiquete',
              'agregar_llanta','editar_llanta','agregar_cliente','editar_cliente',
              'generar_reportes','ver_historial','gestionar_usuarios'],
    'USUARIO': ['ver_kpi','agregar_llanta','editar_llanta',
                'agregar_cliente','editar_cliente',
                'generar_reportes','editar_tiquete'],
}

# En cada función restringida:
def btn_agregar_abono_click():
    if not sesion.tiene_permiso('agregar_abono'):
        return  # El botón ya está visualmente deshabilitado; esto es segunda capa
    # ... lógica normal
