from reportlab.pdfgen import canvas
from reportlab.lib.units import mm
import subprocess, os

def imprimir_orden(datos, coords):
    tmp = os.path.join(BASE_DIR, 'data', 'orden_temp.pdf')
    c = canvas.Canvas(tmp, pagesize=(216*mm, 140*mm))
