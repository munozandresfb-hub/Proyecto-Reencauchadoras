4.3 Principios de Diseño UI
• Espaciado generoso: padding mínimo 12px en cards, 8px entre elementos.
• Bordes sutiles: 1px, color #E0DDD8, radio 8px en cards, 6px en inputs.
• Sombras suaves: cards con relief=flat + borde, sin sombras pesadas.
• Estados visuales claros: hover, selected, disabled bien diferenciados.
• Íconos acompañando texto en todos los botones principales.
• Feedback inmediato: mensajes de éxito/error en la misma vista, no popups molestos.
• Confirmaciones solo en acciones destructivas: eliminar, cambiar tiquete, reasignar cliente.
• Botones restringidos: se muestran en gris/deshabilitados visualmente según el rol del usuario activo — no simplemente bloqueados al hacer clic.
• Labels de campos siempre en mayúsculas pequeñas (10pt, color text_secondary).
5. BASE DE DATOS — MODELOS

5.0 Configuración de Conexión (db.py)
Al iniciar la aplicación, antes de cualquier operación, se deben activar los siguientes PRAGMAs de SQLite:
from sqlalchemy import create_engine, text
from config import DB_PATH

engine = create_engine(f'sqlite:///{DB_PATH}', echo=False)

def init_db():
    with engine.connect() as conn:
        conn.execute(text('PRAGMA journal_mode=WAL'))      # Escritura segura
        conn.execute(text('PRAGMA foreign_keys=ON'))       # Integridad referencial
        conn.execute(text('PRAGMA synchronous=NORMAL'))    # Balance velocidad/seguridad
        conn.execute(text('PRAGMA cache_size=-64000'))     # Cache 64MB
        conn.execute(text('PRAGMA temp_store=MEMORY'))     # Temporales en RAM
        conn.commit()
5.1 Tabla: clientes
CREATE TABLE clientes (
    id            INTEGER PRIMARY KEY AUTOINCREMENT,
    nombre        TEXT NOT NULL,
    nit_cc        TEXT UNIQUE NOT NULL,
    telefono      TEXT,
    direccion     TEXT,
    correo        TEXT,
    asesor        TEXT,            -- COM | VEN | DIR
    tipo          TEXT DEFAULT 'P', -- P=Particular, E=Empresa
    activo        INTEGER DEFAULT 1,
    creado_en     TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    modificado_en TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
CREATE INDEX idx_clientes_nit ON clientes(nit_cc);
CREATE INDEX idx_clientes_nombre ON clientes(nombre);
5.2 Tabla: llantas
CREATE TABLE llantas (
    id                    INTEGER PRIMARY KEY AUTOINCREMENT,
    tiquete               TEXT UNIQUE NOT NULL,
    orden                 TEXT NOT NULL,
    cliente_id            INTEGER NOT NULL REFERENCES clientes(id),
    marca                 TEXT,
    dimension             TEXT,
    disenio               TEXT,         -- Diseño/Banda
    dot_serie             TEXT,
    ubicacion             TEXT DEFAULT 'P',
    estado                TEXT DEFAULT 'PENDIENTE',
    -- Estados válidos:
    -- PENDIENTE | INSPECCION_INICIAL | EN_PROCESO |
    -- INSPECCION_FINAL | REENCAUCHADA | RECHAZADA | REPARADA
    causa_rechazo_id      INTEGER REFERENCES causas_rechazo(id),
    -- Obligatorio cuando estado = RECHAZADA
    resolucion_inspeccion TEXT,
    prioridad             INTEGER DEFAULT 2,
    valor_servicio        REAL,
    observacion           TEXT,
    fecha_entrada         DATE NOT NULL,
    fecha_salida          DATE,
    mes_procesado         INTEGER,
    anio_procesado        INTEGER,
    costo_kg              REAL,
    doc_salida            TEXT,
    creado_en             TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    modificado_en         TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
CREATE INDEX idx_llantas_cliente ON llantas(cliente_id);
CREATE INDEX idx_llantas_estado  ON llantas(estado);
CREATE INDEX idx_llantas_fecha   ON llantas(fecha_entrada);
CREATE INDEX idx_llantas_orden   ON llantas(orden);
